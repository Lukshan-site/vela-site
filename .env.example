# Supabase project credentials — get these from https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-only. NEVER commit this. Used by /admin/new for admin checks.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
